# ============================================================================
# normal people :: environment template
# Copy to .env locally; set these as Railway variables in production.
# ============================================================================

# --- Telegram ---------------------------------------------------------------
HUB_BOT_TOKEN=                  # From @BotFather
TIER1_CHANNEL_ID=               # -100xxxxxxxxxx  (the Library)
TIER2_GROUP_ID=                 # -100xxxxxxxxxx  (the Floor supergroup)
BOOTSTRAP_ADMIN_IDS=            # comma-separated Telegram user_ids (you)

# --- Database (Supabase) ----------------------------------------------------
# Use the "Connection pooling" URI from Supabase → Project Settings → Database
DATABASE_URL=postgresql://postgres:[PASSWORD]@[HOST]:6543/postgres

# --- Behavior tuning --------------------------------------------------------
INVITE_TTL_SECONDS=300          # single-use invite lifespan (5 min default)
CAPTCHA_TTL_SECONDS=120
STRIKE_MUTE_SECONDS=86400       # 24h read-only on Strike 1
STRIKE_DECAY_DAYS=90

LOG_LEVEL=INFO
